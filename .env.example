################################################################################
# AXIOM — SAFE SHADOW / TEST-ONLY EXAMPLE
#
# Copy this file to .env. Never place real secrets in .env or commit .env.
# Secret contents belong in SECRETS_DIR files or a real secret manager.
# Values beginning CHANGE_ME must fail application startup validation.
# Percentage values use decimal fractions: 0.01 means 1% and 1 means 100%.
# Financial values are decimal strings and must never be parsed through float64.
#
# There is intentionally no live/production-order mode, production-private URL,
# production exchange credential, withdrawal, margin, leverage, or transfer key.
################################################################################

# ------------------------------------------------------------------------------
# Docker Compose and immutable images
# ------------------------------------------------------------------------------

COMPOSE_PROJECT_NAME=axiom

# Leave empty until an application image exists. Later examples:
# COMPOSE_PROFILES=app,record,observability
# COMPOSE_PROFILES=app,record,observability,edge
COMPOSE_PROFILES=

# USER-SUPPLIED before enabling an application profile. Prefer an immutable
# sha256 digest on a server rather than a mutable tag.
APP_IMAGE=CHANGE_ME/axiom:CHANGE_ME
APP_PULL_POLICY=missing

POSTGRES_IMAGE=postgres:18.4-alpine
PROMETHEUS_IMAGE=prom/prometheus:v3.5.0
GRAFANA_IMAGE=grafana/grafana:12.0.2
CADDY_IMAGE=caddy:2.10.0-alpine
BACKUP_IMAGE=CHANGE_ME/axiom-backup:CHANGE_ME
BACKUP_PULL_POLICY=missing

APP_UID=10001
# The pinned PostgreSQL 18 Alpine image uses GID 70. Application containers use
# the same primary group solely to read explicitly granted 0640 Compose secrets.
APP_GID=70
HOST_BIND_IP=127.0.0.1
API_HOST_PORT=8080
GRAFANA_HOST_PORT=3000

API_CPU_LIMIT=2.0
API_MEMORY_LIMIT=1g
ENGINE_CPU_LIMIT=4.0
ENGINE_MEMORY_LIMIT=2g
RECORDER_CPU_LIMIT=2.0
RECORDER_MEMORY_LIMIT=2g
WORKER_CPU_LIMIT=4.0
WORKER_MEMORY_LIMIT=4g
POSTGRES_CPU_LIMIT=2.0
POSTGRES_MEMORY_LIMIT=2g
PROMETHEUS_MEMORY_LIMIT=1g
GRAFANA_MEMORY_LIMIT=512m
BACKUP_CPU_LIMIT=1.0
BACKUP_MEMORY_LIMIT=512m
# V1 policy floor; startup rejects values below 14.
BACKUP_RETENTION_GENERATIONS=14
CONTAINER_RESTART_POLICY=unless-stopped

# USER-SUPPLIED server paths/capacity. Keep market data off a small Docker root
# filesystem in long-running deployments.
MARKET_DATA_HOST_PATH=./.local/market-data
SECRETS_DIR=./.secrets

# ------------------------------------------------------------------------------
# Application identity and hard safety posture
# ------------------------------------------------------------------------------

DEPLOYMENT_ENV=local
APP_INSTANCE_ID=axiom-local-shadow-01
APP_TIMEZONE=UTC
COLLECTOR_REGION=local
APP_FAIL_CLOSED=true
APP_SHUTDOWN_TIMEOUT=60s

# Allowed values compiled into V1A: backtest, replay, paper, and shadow.
# Every external-order mode is rejected. Compose public engine uses shadow.
EXECUTION_MODE=shadow

# These files are expected inside the future application image or mounted by a
# deployment-specific override. Research/risk policy is versioned and audited.
APP_CONFIG_FILE=/etc/axiom/platform.json
RISK_POLICY_FILE=/etc/axiom/risk-shadow.yaml

HTTP_BIND_ADDRESS=0.0.0.0:8080
METRICS_BIND_ADDRESS=0.0.0.0:9091
HEALTH_DETAIL_TOKEN_FILE=/run/secrets/health_detail_token

# USER-SUPPLIED for a server deployment.
API_PUBLIC_BASE_URL=http://localhost:8080
WEB_ALLOWED_ORIGINS=http://localhost:8080
TRUST_PROXY_HEADERS=false

# Optional Caddy edge profile. Replace before exposing a server publicly.
APP_DOMAIN=localhost
ACME_EMAIL=CHANGE_ME@example.invalid

# ------------------------------------------------------------------------------
# PostgreSQL — secret values are separate files
# ------------------------------------------------------------------------------

POSTGRES_DB=axiom
POSTGRES_OWNER_USER=axiom_owner
POSTGRES_MIGRATOR_USER=axiom_migrator
POSTGRES_RUNTIME_USER=axiom_app
POSTGRES_RECORDER_USER=axiom_recorder
POSTGRES_BACKUP_USER=axiom_backup
POSTGRES_READONLY_USER=axiom_readonly

# USER-SUPPLIED files before first database initialization. For this local
# file-backed Compose model, use the service-specific group ownership and 0640
# modes documented in deploy/README.md and ADR-0009; never make them
# other-readable. Production-like secret delivery should use per-task ownership.
# .secrets/postgres_owner_password
# .secrets/postgres_migrator_password
# .secrets/postgres_runtime_password
# .secrets/postgres_recorder_password
# .secrets/postgres_backup_password
# .secrets/backup_encryption_key (base64 encoding of exactly 32 random bytes)
# .secrets/postgres_readonly_password

DB_HOST=postgres
DB_PORT=5432
DB_NAME=axiom
DB_SSL_MODE=disable
DB_MAX_OPEN_CONNECTIONS=30
DB_CONNECTION_MAX_LIFETIME=30m
DB_CONNECTION_TIMEOUT=5s
DB_STATEMENT_TIMEOUT=10s

# A5 adds an independent opaque token for detailed operational health. The
# public liveness/readiness/build endpoints never expose dependency details.
# .secrets/health_detail_token (at least 32 random bytes)
# Session, CSRF, bootstrap, and TOTP secrets remain absent until A11.
# Grafana requires `.secrets/grafana_admin_password` when enabled.

# Asset eligibility, executable instruments, datasets, virtual-capital
# allocation, valuation, and reporting policy belong only to the immutable,
# versioned research configuration selected by APP_CONFIG_FILE. They are
# intentionally not environment overrides. V1A's initial file must contain the
# exact USDT/BTC/ETH registry, BTC-USDT and ETH-USDT instruments, 500.00 virtual
# USDT allocation, and disabled USD reporting required by the reviewed policy.

# ------------------------------------------------------------------------------
# Production PUBLIC market data only — clients cannot sign requests
# ------------------------------------------------------------------------------

BINANCE_PUBLIC_MARKET_DATA_ENABLED=true
# Closed, code-owned identifier. V1A maps it to data-api.binance.vision:443
# and data-stream.binance.vision:443 with the exact public route allowlist.
BINANCE_PUBLIC_ENDPOINT_SET=market-data-only-v1

EXCHANGE_HTTP_TIMEOUT=5s
EXCHANGE_TIME_SYNC_INTERVAL=30s
EXCHANGE_METADATA_REFRESH_INTERVAL=1h
EXCHANGE_RECONNECT_MIN_BACKOFF=1s
EXCHANGE_RECONNECT_MAX_BACKOFF=30s

# Virtual-mode reconciliation has no external account or credential path.
RECONCILIATION_ON_START=true
RECONCILIATION_ON_RECONNECT=true
RECONCILIATION_INTERVAL=30s

# ------------------------------------------------------------------------------
# Recorder, deterministic datasets, storage pressure, and backup
# ------------------------------------------------------------------------------

RECORDER_ENABLED=true
RECORDER_STORE_RAW_PAYLOADS=true
RECORDER_STORE_NORMALIZED_EVENTS=true
RECORDER_ROOT=/var/lib/axiom/market-data
RECORDER_TEMP_ROOT=/var/lib/axiom/market-data/.tmp
RECORDER_FORMAT=parquet
RECORDER_COMPRESSION=zstd
RECORDER_ZSTD_LEVEL=3
RECORDER_CHECKSUM=sha256
RECORDER_SEGMENT_DURATION=5m
RECORDER_SEGMENT_MAX_BYTES=268435456
RECORDER_FLUSH_INTERVAL=5m
RECORDER_FSYNC_ON_FINALIZE=true

# USER-SUPPLIED after measuring server storage and expected bytes/day.
RECORDER_RETENTION_DAYS=30
RECORDER_MIN_FREE_BYTES=10737418240
RECORDER_DISK_PRESSURE_ACTION=pause_new_decisions

MARKET_EVENT_QUEUE_CAPACITY=16384
PERSISTENCE_QUEUE_CAPACITY=8192
ORDER_BOOK_RETAINED_DEPTH=1000

# The `backup` profile creates one authenticated encrypted restore point in its
# independent Docker volume. Schedule this reviewed one-shot service daily and
# retain 14 verified generations as documented in deploy/README.md.

# ------------------------------------------------------------------------------
# Observability and alert delivery
# ------------------------------------------------------------------------------

LOG_LEVEL=info
LOG_FORMAT=json
LOG_OUTPUT=stdout
METRICS_ENABLED=true
PPROF_ENABLED=false
PROMETHEUS_RETENTION_TIME=15d
PROMETHEUS_RETENTION_SIZE=20GB

GRAFANA_ADMIN_USER=admin
GRAFANA_ANONYMOUS_ACCESS=false

# Optional A5 OTLP/HTTP tracing. Disabled is a true no-op. When enabled, use a
# full HTTPS endpoint with no userinfo, query, or fragment; do not put exporter
# credentials in this file or URL. Export is bounded/asynchronous and may drop
# spans rather than block application work.
OTEL_TRACING_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=

ALERT_IN_APP_ENABLED=true
ALERT_WEBHOOK_ENABLED=false

# USER-SUPPLIED only when webhook delivery is enabled. The URL must be HTTPS,
# contain no credentials/query/fragment, and match the explicit host exactly.
ALERT_WEBHOOK_URL=
ALERT_WEBHOOK_ALLOWED_HOST=
# Mount a narrow secret file with a deployment override only when bearer auth
# is required; never embed it in the webhook URL.
ALERT_WEBHOOK_TOKEN_FILE=

# ------------------------------------------------------------------------------
# Conservative safety envelope
#
# Canonical mutable policy belongs in the versioned risk file/database. These
# deployment caps may tighten it but must never loosen it silently.
# ------------------------------------------------------------------------------

RISK_INITIAL_STATE=PAUSED
RISK_AUTO_UNPAUSE=false
RISK_FAIL_CLOSED=true
RISK_REQUIRE_HEALTHY_BOOK=true

RISK_MAX_ACCOUNT_DRAWDOWN_PCT=5.00
RISK_MAX_DAILY_LOSS_PCT=1.00
RISK_MAX_STRATEGY_LOSS_PCT=3.00
RISK_MAX_SINGLE_VOLATILE_ASSET_EXPOSURE_PCT=30.00
RISK_MAX_TOTAL_VOLATILE_ASSET_EXPOSURE_PCT=50.00
RISK_MAX_EXCHANGE_EXPOSURE_PCT=60.00
RISK_MIN_GLOBAL_RESERVE_PCT=15.00
RISK_MAX_RESERVED_CAPITAL_PCT=85.00

RISK_MAX_OPEN_ORDERS=8
RISK_MAX_SPREAD_BPS=100
RISK_MAX_SLIPPAGE_BPS=50
RISK_ARBITRAGE_ADDITIONAL_SAFETY_BUFFER_BPS=15
RISK_ARBITRAGE_MAX_BOOK_AGE_MS=250
RISK_MAX_QUEUE_LAG_MS=250
RISK_MAX_CLOCK_DRIFT_MS=100
RISK_MIN_MARKET_DATA_QUALITY_SCORE=90

RISK_LOCK_ON_UNKNOWN_ORDER=true
RISK_LOCK_ON_RECONCILIATION_MISMATCH=true
RISK_LOCK_ON_CRITICAL_PERSISTENCE_FAILURE=true
